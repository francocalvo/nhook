# Webhook secret key (must match X-Calvo-Key header from Notion automation)
WEBHOOK_SECRET_KEY=your-secret-key-here

# Notion API token (get from https://www.notion.so/my-integrations)
NOTION_API_TOKEN=secret_xxxxx

# Database IDs (defaults provided, override if needed)
CRONOGRAMA_DATABASE_ID=2f5f6e7f-0572-80e3-a411-000be22f385d
GASTOS_DATABASE_ID=2e2f6e7f-0572-8010-9fb8-000b7db49de1
PASAJES_DATABASE_ID=default-pasajes-db-id

# Server settings
HOST=0.0.0.0
PORT=8000
DEBUG=false
